// ── STATE ─────────────────────────────────────────────────────────────────────
var ans={}, qlist=[], idx=0;

// ── SCREENS ───────────────────────────────────────────────────────────────────
function showScreen(id){
  document.getElementById('sd-gate').classList.toggle('active', id==='landing' && DIAGNOSTIC_LOCKED);
  document.getElementById('sd-landing').style.display = id==='landing' && !DIAGNOSTIC_LOCKED ? '' : 'none';
  document.getElementById('sd-capture').classList.toggle('active', id==='capture');
  document.getElementById('sd-email-capture').classList.toggle('active', id==='email');
  document.getElementById('sd-quiz').classList.toggle('active', id==='quiz');
  document.getElementById('sd-loading').classList.toggle('active', id==='loading');
  document.getElementById('sd-results').classList.toggle('active', id==='results');
  window.scrollTo(0,0);
}

// ── BUILD LIST ────────────────────────────────────────────────────────────────
function buildList(){
  qlist=B1.concat([Q9]);
}

function personalize(text){
  var firstName=document.getElementById('sd-firstname').value.trim();
  var safeFirstName=firstName.replace(/[&<>"']/g,function(character){
    return {'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#039;'}[character];
  });
  return text.replace(/\[\[firstName\]\]/g, safeFirstName);
}

// ── RENDER QUESTION ───────────────────────────────────────────────────────────
function renderQ(){
  buildList();
  var q=qlist[idx];
  var total=qlist.length;
  document.getElementById('sd-step-label').textContent='Question '+(idx+1)+' / '+total;
  var pct=Math.round((idx+1)/qlist.length*100);
  document.getElementById('sd-progress').style.width=pct+'%';

  var sel=ans[q.id];
  var isMulti=!!q.multi;
  var isLast=idx===qlist.length-1;

  var optsHtml=q.o.map(function(opt){
    var isSel=isMulti?(Array.isArray(sel)&&sel.indexOf(opt.k)>-1):sel===opt.k;
    var mediaHtml=opt.img?'<span class="sd-opt__media"><img class="sd-opt__img" src="'+opt.img+'" alt="'+opt.l+'"></span>':'';
    return '<button class="sd-opt'+(isSel?' selected':'')+'" data-k="'+opt.k+'">'
      +'<span class="sd-opt__content">'
      +'<span class="sd-opt__key">'+opt.k+'</span>'
      +mediaHtml
      +'<span class="sd-opt__label">'+opt.l+'</span>'
      +'</span>'
      +'</button>';
  }).join('');

  var canNext=isMulti?(Array.isArray(sel)&&sel.length>0):!!sel;
  var nextTxt=isLast?'Voir mes résultats →':'Question suivante →';

  var card=document.getElementById('sd-qcard');
  card.innerHTML='<div class="sd-quiz__qnum">'+q.id+'</div>'
    +'<h2 class="sd-quiz__question">'+personalize(q.t)+'</h2>'
    +(q.sub?'<p class="sd-quiz__subtitle">'+personalize(q.sub)+'</p>':'')
    +'<div class="sd-quiz__options">'+optsHtml+'</div>'
    +'<div class="sd-quiz__nav">'
    +(idx>0?'<button class="sd-quiz__back" id="sd-back">← Retour</button>':'<span></span>')
    +'<button class="sd-btn sd-btn--primary" id="sd-next"'+(canNext?'':' disabled style="opacity:.4;cursor:not-allowed;"')+'>'+nextTxt+'</button>'
    +'</div>';

  card.querySelectorAll('.sd-opt').forEach(function(btn){
    btn.addEventListener('click',function(){
      var k=this.getAttribute('data-k');
      if(isMulti){
        var cur=Array.isArray(ans[q.id])?ans[q.id].slice():[];
        var i=cur.indexOf(k);
        if(i>-1){cur.splice(i,1);}
        else if(cur.length<(q.max||2)){cur.push(k);}
        ans[q.id]=cur;
      } else {
        ans[q.id]=k;
      }
      renderQ();
    });
  });

  var nb=document.getElementById('sd-next');
  if(nb) nb.addEventListener('click',function(){
    if(isLast){showScreen('email');return;}
    idx++;renderQ();
  });
  var bb=document.getElementById('sd-back');
  if(bb) bb.addEventListener('click',function(){idx--;renderQ();});
}

// ── COMPUTE ───────────────────────────────────────────────────────────────────
function compute(){
  var raw=0;
  B1.forEach(function(q){
    var a=ans[q.id]; if(!a) return;
    var opt=q.o.find(function(o){return o.k===a;}); if(!opt) return;
    raw+=opt.s*W[q.v];
  });
  var norm=Math.round(raw*SF);
  var cl=Math.max(-100,Math.min(100,norm));
  var neu=B1.filter(function(q){return q.v!=='hair_type'&&ans[q.id]==='B';}).length;
  var rel=Math.max(0,100-neu*5);
  var profileKey='moyenne';
  if(cl<0){ profileKey = cl<=-30 ? 'haute' : 'moyenne'; }
  else if(cl>0){ profileKey = cl>=30 ? 'faible' : 'moyenne'; }
  return{cl:cl,rel:rel,profileKey:profileKey};
}

// ── SAVE PROFILE ───────────────────────────────────────────────────────────
async function saveProfile(firstName, lastName, email, result) {
  var bucket = result.cl > 30 ? 'haute_elevee'
             : result.cl > 0  ? 'haute_mixte'
             : result.cl > -30 ? 'faible_mixte'
             : 'faible_elevee';

  var textureMap = { A: 'bouclee', B: 'frisee', C: 'crepue', D: 'lisse' };
  var texture = textureMap[ans.Q10] || 'inconnu';
  var concerns = Array.isArray(ans.Q9) ? ans.Q9.join('-') : '';
  var today = new Date().toISOString().split('T')[0];

  var tags = [
    'shema_diagnostic',
    'shema_porosity:' + bucket,
    'shema_score:' + result.cl,
    'shema_reliability:' + result.rel,
    'shema_texture:' + texture,
    'shema_bundle:' + (result.cl < 0 ? 'haute_porosite' : 'faible_porosite'),
    'shema_date:' + today,
    concerns ? 'shema_concerns:' + concerns : null
  ].filter(Boolean).join(', ');

  try {
    var res = await fetch(CREATE_CUSTOMER_API_URL, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({
        firstName: firstName,
        lastName: lastName,
        email: email,
        tags: tags
      })
    });

    var data = await res.json();
    if (!res.ok) {
      console.warn('SHEMA saveProfile error:', data);
    }
  } catch (e) {
    console.warn('SHEMA saveProfile fetch error:', e);
  }
}

// ── SHOW RESULTS ──────────────────────────────────────────────────────────────
function showResults(shouldSave){
  showScreen('loading');
  window.setTimeout(function(){
    var r=compute();
    var p=PROFILES[r.profileKey];
    var firstName=document.getElementById('sd-firstname').value.trim();
    var lastName=document.getElementById('sd-lastname').value.trim();
    var email=document.getElementById('sd-email').value.trim();
    var tMap={A:'Bouclée',B:'Frisée',C:'Crépue',D:'Lisse'};
    var cMap={A:'Casse',B:'Pousse',C:'Alopécie',D:'Cuir chevelu sec ou irrité',E:'Cheveux secs'};

    document.getElementById('r-title').textContent=p.title;
    document.getElementById('r-subtitle').textContent=r.profileKey==='moyenne'?'profil intermédiaire':'';
    document.getElementById('r-texture').textContent=tMap[ans.Q10]||'—';

    var cKeys=Array.isArray(ans.Q9)?ans.Q9:[];
    var cSec=document.getElementById('r-concerns-section');
    if(cKeys.length>0){
      cSec.style.display='';
      document.getElementById('r-concerns').innerHTML=cKeys.map(function(k){
        return '<span class="sd-concern-pill">'+cMap[k]+'</span>';
      }).join('');
    } else { cSec.style.display='none'; }

    document.getElementById('r-desc').textContent=p.desc;
    document.getElementById('r-tips').innerHTML=p.tips.map(function(t){return'<li>'+t+'</li>';}).join('');
    document.getElementById('r-schedule').textContent=p.schedule;
    document.getElementById('r-bundle-name').textContent=p.bundle;
    document.getElementById('r-bundle-products').textContent=p.products;

    var identityButton=document.getElementById('r-identity-btn');
    var accountTitle=document.getElementById('r-account-title');
    var accountDesc=document.getElementById('r-account-desc');
    var accountNote=document.getElementById('r-account-note');
    if(shouldSave){
      identityButton.style.display='';
      accountTitle.textContent='Votre espace SHEMA est presque prêt';
      accountDesc.textContent="Votre compte a bien été créé. Pour accéder à votre espace personnel, vous devez maintenant valider votre compte depuis l'email qui vient de vous être envoyé.";
      accountNote.style.display='';
      saveProfile(firstName, lastName, email, r).catch(function(){});
    } else {
      identityButton.style.display='none';
      accountTitle.textContent='Ton diagnostic est disponible';
      accountDesc.textContent="Aucune information n'a été enregistrée. Tu peux consulter ton diagnostic librement sur cette page.";
      accountNote.style.display='none';
    }
    showScreen('results');
    initResultsReveal();
  }, 1500);
}

// ── CTA HANDLER ───────────────────────────────────────────────────────────────
function goBundle(){
  if(BUNDLE_URL){ window.location.href=BUNDLE_URL; }
  else { alert('Lien bundle à configurer dans l\'éditeur de thème (panneau gauche → Liens).'); }
}
function goCoaching(){
  if(COACHING_URL){ window.location.href=COACHING_URL; }
  else { alert('Lien coaching à configurer dans l\'éditeur de thème (panneau gauche → Liens).'); }
}
function goAccount(){
  window.location.href=ACCOUNT_URL;
}
function openIdentityModal(){
  var modal=document.getElementById('sd-identity-modal');
  modal.classList.add('active');
  modal.setAttribute('aria-hidden','false');
}
function closeIdentityModal(){
  var modal=document.getElementById('sd-identity-modal');
  modal.classList.remove('active');
  modal.setAttribute('aria-hidden','true');
}
function initResultsReveal(){
  var items=document.querySelectorAll('#sd-results .sd-scroll-reveal');
  if(!items.length) return;

  if(window.matchMedia('(prefers-reduced-motion: reduce)').matches || !('IntersectionObserver' in window)){
    items.forEach(function(item){ item.classList.add('is-visible'); });
    return;
  }

  items.forEach(function(item){ item.classList.remove('is-visible'); });

  var observer=new IntersectionObserver(function(entries){
    entries.forEach(function(entry){
      if(entry.isIntersecting){
        entry.target.classList.add('is-visible');
        observer.unobserve(entry.target);
      }
    });
  }, { threshold: 0.16, rootMargin: '0px 0px -8% 0px' });

  items.forEach(function(item){
    if(item.style.display==='none') return;
    observer.observe(item);
  });
}

// ── INIT ──────────────────────────────────────────────────────────────────────
showScreen('landing');

document.getElementById('sd-hero-cta').addEventListener('click',function(){showScreen('capture');});
document.getElementById('sd-cta-bottom').addEventListener('click',function(){showScreen('capture');});
document.getElementById('sd-gate-identity').addEventListener('click', goAccount);
document.getElementById('sd-gate-account').addEventListener('click', goAccount);

document.getElementById('sd-capture-next').addEventListener('click',function(){
  var ln=document.getElementById('sd-lastname').value.trim();
  var fn=document.getElementById('sd-firstname').value.trim();
  if(!ln||!fn){
    alert('Veuillez renseigner votre nom et votre prénom.');
    return;
  }
  ans={};idx=0;
  showScreen('quiz');
  renderQ();
});

document.getElementById('sd-email-next').addEventListener('click',function(){
  var email=document.getElementById('sd-email').value.trim();
  if(!/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email)){
    alert('Veuillez renseigner une adresse email valide.');
    return;
  }
  showResults(true);
});

document.getElementById('sd-email-skip').addEventListener('click',function(){
  document.getElementById('sd-email').value='';
  showResults(false);
});

document.getElementById('r-bundle-btn').addEventListener('click', goBundle);
document.getElementById('r-cta-routine').addEventListener('click', goBundle);
document.getElementById('r-cta-coaching').addEventListener('click', goCoaching);
document.getElementById('r-identity-btn').addEventListener('click', openIdentityModal);
document.getElementById('sd-modal-account').addEventListener('click', goAccount);
document.getElementById('sd-modal-close').addEventListener('click', closeIdentityModal);
document.getElementById('sd-modal-close-secondary').addEventListener('click', closeIdentityModal);
document.querySelectorAll('[data-close-modal]').forEach(function(el){
  el.addEventListener('click', closeIdentityModal);
});

document.getElementById('r-restart').addEventListener('click',function(){
  ans={};idx=0;
  document.getElementById('sd-lastname').value='';
  document.getElementById('sd-firstname').value='';
  document.getElementById('sd-email').value='';
  showScreen('landing');
});

})();
</script>


