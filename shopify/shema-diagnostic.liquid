  {id:'Q5',v:'buildup',t:'[[firstName]], après plusieurs applications de produits…',o:[{k:'A',l:'Mes cheveux restent légers',s:2},{k:'B',l:'Deviennent un peu lourds',s:0},{k:'C',l:'Deviennent gras ou collants',s:-2}]},
  {id:'Q6',v:'humidity',t:'[[firstName]], par temps humide ou sous la pluie…',o:[{k:'A',l:'Mes cheveux gonflent rapidement',s:2},{k:'B',l:'Peu de changement visible',s:0},{k:'C',l:'Restent inchangés / rigides',s:-2}]},
