  {id:'Q8',v:'elasticity',t:'[[firstName]], quand tu étires un cheveu…',sub:'Prends un cheveu entre tes doigts et tire doucement',o:[{k:'A',l:'Il casse immédiatement',s:2},{k:'B',l:"Il s'étire un peu puis casse",s:0},{k:'C',l:"Il s'étire et revient à sa forme",s:-2}]}
];

var Q9={id:'Q9',t:'[[firstName]], quelles sont tes 2 principales problématiques ?',sub:"Sélectionne jusqu'à 2 réponses",multi:true,max:2,o:[{k:'A',l:'Casse',s:0},{k:'B',l:'Pousse',s:0},{k:'C',l:'Alopécie',s:0},{k:'D',l:'Cuir chevelu sec ou irrité',s:0},{k:'E',l:'Cheveux secs',s:0}]};

var PROFILES={
